{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "*": [
                "../node_modules/*"
            ]
        },
        "module": "CommonJS",
        "target": "ES6",
        "allowJs": true,
        "checkJs": true,
        "strict": true,
        "jsx": "react-jsx"
    },
    "include": [
        "src/**/*",
        "src/**/*.d.ts"
    ]
}
